# Local development keeps using JSON files when DATABASE_URL is empty.
# Set DATABASE_URL to switch cards, contributions, and media metadata to PostgreSQL.
DATABASE_URL=

# Public base URL for generated participant/manage/preview/gift links.
NEXT_PUBLIC_SITE_URL=https://steplom.ru

# Production example:
# DATABASE_URL=postgres://capsule:change-me@localhost:5432/capsule

# User photos are stored locally in public/uploads/cards for the first VPS release.
# Back up that directory together with PostgreSQL.

# Admin panel credentials.
# Generate ADMIN_PASSWORD_HASH and ADMIN_PASSWORD_SALT with:
#   node scripts/generate-admin-password.mjs
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
ADMIN_SESSION_SECRET=
