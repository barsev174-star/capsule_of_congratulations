# Local development keeps using JSON files when DATABASE_URL is empty.
# Set DATABASE_URL to switch cards, contributions, and media metadata to PostgreSQL.
DATABASE_URL=

# Public base URL for generated participant/manage/preview/gift links.
NEXT_PUBLIC_SITE_URL=https://steplom.ru

# Passwordless organizer account and email delivery.
ORGANIZER_SESSION_SECRET=
RESEND_API_KEY=
CRON_SECRET=
EMAIL_FROM=Дари слова <hello@example.com>

# Production example:
# DATABASE_URL=postgres://capsule:change-me@localhost:5432/capsule

# User photos are stored locally in public/uploads/cards for the first VPS release.
# Back up that directory together with PostgreSQL.

# Admin panel credentials.
# Generate ADMIN_PASSWORD_HASH and ADMIN_PASSWORD_SALT with:
#   node scripts/generate-admin-password.mjs
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
ADMIN_SESSION_SECRET=

# AI greeting helper. Keep all provider keys server-side only.
AI_PROVIDER=mock
AI_GREETING_PROVIDER=
# ladder is the production candidate; use matrix for an immediate rollback.
AI_GREETING_MODE=ladder
AI_MATRIX_PROMPT_VERSION=greeting-openai-matrix-v4
AI_INSIGHTS_PROVIDER=openai
AI_FREE_LIMIT=5
AI_PAID_LIMIT=30
# OpenAI-compatible provider (OpenAI or RouterAI). Keep the key server-side only.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_MS=45000
