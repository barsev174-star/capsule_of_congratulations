{
  "name": "capsule-of-congratulations",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "brand:assets": "node scripts/build-brand-assets.mjs",
    "brand:check": "node scripts/check-brand-layouts.mjs",
    "start": "next start",
    "lint": "eslint .",
    "preflight": "npm run lint && npm test && npm run build && npm run smoke:local && npm run smoke:admin && npm run smoke:retention",
    "smoke:local": "node --env-file=.env.local scripts/smoke-local.mjs",
    "smoke:admin": "node --env-file=.env.local scripts/smoke-admin-local.mjs",
    "smoke:retention": "node --env-file=.env.local scripts/smoke-retention-local.mjs",
    "db:migrate": "node scripts/migrate-postgres.mjs",
    "cleanup:prelaunch": "node --experimental-strip-types scripts/cleanup-prelaunch-user-data.ts",
    "ai:check": "node --env-file=.env.local scripts/check-gigachat.mjs",
    "test": "vitest run",
    "test:greetings:matrix": "vitest run src/lib/ai/openai-provider.live.test.ts --reporter=verbose",
    "test:greetings:levels": "vitest run src/lib/ai/openai-assistance-levels.live.test.ts --reporter=verbose",
    "test:greetings:semantic-corpus": "vitest run src/lib/ai/greeting-semantic-fixtures.test.ts --reporter=verbose",
    "test:greetings:semantic-live": "vitest run src/lib/ai/greeting-semantic-evaluation.live.test.ts --reporter=verbose",
    "test:reminders:email:live": "node --env-file=.env.local scripts/run-reminder-email-live.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "next": "^16.0.1",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.0.1",
    "jsdom": "^27.2.0",
    "playwright-core": "^1.61.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
