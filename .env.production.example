POSTGRES_DB=capsule
POSTGRES_USER=capsule
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgres://capsule:change-me@postgres:5432/capsule
NEXT_PUBLIC_SITE_URL=https://darislova.ru

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Host binding for the web container. Keep this local-only; Caddy should be the public entrypoint.
WEB_BIND=127.0.0.1
WEB_PORT=3100

# AI greeting helper. Set the authorization key only in .env.production on the VPS.
AI_PROVIDER=mock
AI_FREE_LIMIT=5
AI_PAID_LIMIT=30
GIGACHAT_AUTH_KEY=
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_GREETING_MODEL=GigaChat-2-Pro
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT_MS=20000
