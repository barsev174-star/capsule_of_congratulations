POSTGRES_DB=capsule
POSTGRES_USER=capsule
POSTGRES_PASSWORD=change-me

DATABASE_URL=postgres://capsule:change-me@postgres:5432/capsule
NEXT_PUBLIC_SITE_URL=https://slovesto.ru
PUBLICATION_MODE=free
# Robokassa. ResultURL in its dashboard must be https://your-domain/api/payments/robokassa/result
ROBOKASSA_MODE=test
ROBOKASSA_TEST_PASSWORD_1=
ROBOKASSA_TEST_PASSWORD_2=
ROBOKASSA_TEST_PASSWORD_3=
ROBOKASSA_LIVE_PASSWORD_1=
ROBOKASSA_LIVE_PASSWORD_2=
ROBOKASSA_LIVE_PASSWORD_3=
ROBOKASSA_HASH_ALGORITHM=SHA256
ROBOKASSA_RESULT_URL=https://slovesto.ru/api/payments/robokassa/result
ROBOKASSA_SUCCESS_URL=https://slovesto.ru/payment/success
ROBOKASSA_FAIL_URL=https://slovesto.ru/payment/fail
CARD_FINAL_PRICE_KOPECKS=39900
ROBOKASSA_RECEIPT_PAYMENT_METHOD=
ORGANIZER_SESSION_SECRET=change-this-to-a-long-random-secret
RESEND_API_KEY=
CRON_SECRET=change-this-to-a-long-random-secret
REMINDER_TIME_ZONE=Asia/Yekaterinburg
REMINDER_TOKEN_SECRET=change-this-to-an-independent-long-random-secret
EMAIL_FROM=Slovesto <hello@mail.slovesto.ru>
# Set only after a receiving mailbox or forwarding exists.
EMAIL_REPLY_TO=

# Admin panel. Generate hash, salt and a session secret locally with:
#   node scripts/generate-admin-password.mjs
# Copy only the generated values to the VPS secret env file.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD_SALT=
ADMIN_SESSION_SECRET=change-this-to-an-independent-long-random-secret

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Host binding for the web container. Keep this local-only; Caddy should be the public entrypoint.
WEB_BIND=127.0.0.1
WEB_PORT=3100

# AI greeting helper. Set provider keys only in .env.production on the VPS.
AI_PROVIDER=openai
AI_GREETING_PROVIDER=openai
# ladder is the production candidate; use matrix for an immediate rollback.
AI_GREETING_MODE=ladder
AI_MATRIX_PROMPT_VERSION=greeting-openai-matrix-v4
AI_INSIGHTS_PROVIDER=openai
AI_FREE_LIMIT=5
AI_PAID_LIMIT=30
OPENAI_API_KEY=
OPENAI_BASE_URL=https://routerai.ru/api/v1
OPENAI_MODEL=openai/gpt-5-mini
OPENAI_TIMEOUT_MS=60000
